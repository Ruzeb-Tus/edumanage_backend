<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<!-- ═══════════════════════════════════════════════════════════
     EduManage Setup — Full-Screen Onboarding Shell
     ═══════════════════════════════════════════════════════════ -->
<t t-name="edumanage_setup.SetupClient" owl="1">

  <!-- Google Fonts loaded at runtime -->
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous"/>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&amp;family=Bricolage+Grotesque:wght@400;500;600;700;800&amp;display=swap"/>

  <div class="em-setup-shell">

    <!-- ── Top Bar ──────────────────────────────────────────── -->
    <header class="em-topbar">

      <!-- Brand -->
      <div class="em-topbar-brand">
        <div class="em-topbar-logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 3L2 8l10 5 10-5-10-5zM2 14l10 5 10-5M2 19l10 5 10-5"/>
          </svg>
        </div>
        <span class="em-topbar-wordmark">Edu<span>Manage</span></span>
      </div>

      <!-- Step Progress -->
      <nav class="em-progress-track">
        <t t-foreach="getStepMeta()" t-as="s" t-key="s.step">
          <div t-attf-class="em-progress-step {{ stepClass(s) }}">
            <div class="em-progress-bubble">
              <t t-if="stepClass(s) === 'done'">
                <svg viewBox="0 0 16 16" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width:12px;height:12px">
                  <polyline points="3 8 6.5 11.5 13 5"/>
                </svg>
              </t>
              <t t-else=""><t t-out="s.step"/></t>
            </div>
            <span class="em-progress-label"><t t-out="s.label"/></span>
          </div>
          <t t-if="s_index lt getStepMeta().length - 1">
            <div t-attf-class="em-progress-connector {{ connectorClass(s_index) }}"/>
          </t>
        </t>
      </nav>

      <!-- Step count -->
      <span class="em-step-count">Step <t t-out="state.step"/> of 3</span>

    </header>

    <!-- ── Main Content ──────────────────────────────────────── -->
    <main class="em-main">

      <!-- ── STEP 1 · Identity ──────────────────────────────── -->
      <t t-if="state.step === 1">

        <div class="em-hero">
          <div class="em-hero-eyebrow">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:12px;height:12px">
              <polygon points="8 1 10.09 6.26 16 7.27 12 11.14 12.91 17.02 8 14.47 3.09 17.02 4 11.14 0 7.27 5.91 6.26 8 1"/>
            </svg>
            Institution Setup
          </div>
          <h1 class="em-hero-title">Set up your <em>institution</em></h1>
          <p class="em-hero-subtitle">
            Tell us about your organisation so EduManage can personalise
            your experience from day one.
          </p>
        </div>

        <div class="em-card" style="max-width:900px;width:100%">

          <!-- Institution Type -->
          <div class="em-card-section">
            <div class="em-section-label">
              <div class="em-section-label-dot"/>
              <span class="em-section-label-text">What kind of institution are you?</span>
            </div>

            <div class="em-type-grid">

              <!-- School Card -->
              <div t-attf-class="em-type-card {{ state.institutionType === 'school' ? 'selected' : '' }}"
                   t-on-click="() =&gt; selectType('school')">
                <div class="em-type-radio"><div class="em-type-radio-dot"/></div>
                <div class="em-type-card-inner">
                  <div class="em-type-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                      <polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                  </div>
                  <h3 class="em-type-title">School</h3>
                  <p class="em-type-desc">Formal academic institutions with structured curricula and grades.</p>
                  <div class="em-type-features">
                    <div class="em-type-feature">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 8 6 11 13 5"/></svg>
                      Classes &amp; Sections management
                    </div>
                    <div class="em-type-feature">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 8 6 11 13 5"/></svg>
                      Board affiliations &amp; reports
                    </div>
                    <div class="em-type-feature">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 8 6 11 13 5"/></svg>
                      Parent &amp; student portals
                    </div>
                  </div>
                </div>
              </div>

              <!-- Tuition Centre Card -->
              <div t-attf-class="em-type-card {{ state.institutionType === 'tuition' ? 'selected' : '' }}"
                   t-on-click="() =&gt; selectType('tuition')">
                <div class="em-type-radio"><div class="em-type-radio-dot"/></div>
                <div class="em-type-card-inner">
                  <div class="em-type-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                      <circle cx="12" cy="12" r="10"/>
                      <polyline points="12 6 12 12 16 14"/>
                    </svg>
                  </div>
                  <h3 class="em-type-title">Tuition Centre</h3>
                  <p class="em-type-desc">Coaching institutes and flexible learning environments.</p>
                  <div class="em-type-features">
                    <div class="em-type-feature">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 8 6 11 13 5"/></svg>
                      Flexible batch management
                    </div>
                    <div class="em-type-feature">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 8 6 11 13 5"/></svg>
                      Subject &amp; teacher scheduling
                    </div>
                    <div class="em-type-feature">
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 8 6 11 13 5"/></svg>
                      Fee collection &amp; receipts
                    </div>
                  </div>
                </div>
              </div>

            </div>

            <t t-if="state.errors.institutionType">
              <p class="em-error-msg" style="margin-top:10px"><t t-out="state.errors.institutionType"/></p>
            </t>
          </div>

          <div class="em-divider"/>

          <!-- Institution Name -->
          <div class="em-card-section">
            <div class="em-section-label">
              <div class="em-section-label-dot"/>
              <span class="em-section-label-text">Institution Identity</span>
            </div>

            <div class="em-logo-upload" style="margin-bottom:28px">
              <div t-attf-class="em-logo-drop-zone {{ state.logoPreview ? 'has-logo' : '' }}"
                   t-on-click="triggerFileInput"
                   t-on-dragover="onDragOver"
                   t-on-dragleave="onDragLeave"
                   t-on-drop="onDrop">
                <t t-if="state.logoPreview">
                  <img t-att-src="state.logoPreview" alt="Institution logo preview"/>
                  <div class="em-logo-drop-overlay">
                    <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" style="width:24px;height:24px">
                      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                      <polyline points="17 8 12 3 7 8"/>
                      <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                  </div>
                </t>
                <t t-else="">
                  <div class="em-logo-drop-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                  </div>
                  <span class="em-logo-drop-text">Drop logo here</span>
                </t>
              </div>

              <div class="em-logo-meta">
                <div class="em-logo-meta-title">Institution Logo</div>
                <p class="em-logo-meta-desc">
                  Upload your institution's logo or crest.<br/>
                  This will appear on reports, certificates, and your portal.
                </p>
                <div class="em-logo-actions">
                  <button class="em-btn-ghost-sm" t-on-click="triggerFileInput">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                      <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/>
                      <polyline points="17 8 12 3 7 8"/>
                      <line x1="12" y1="3" x2="12" y2="15"/>
                    </svg>
                    <t t-if="state.logoPreview">Replace Logo</t>
                    <t t-else="">Upload Logo</t>
                  </button>
                  <t t-if="state.logoPreview">
                    <button class="em-btn-ghost-sm" t-on-click="removeLogo">
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6l-1 14H6L5 6"/>
                        <path d="M10 11v6M14 11v6"/>
                        <path d="M9 6V4h6v2"/>
                      </svg>
                      Remove
                    </button>
                  </t>
                </div>
              </div>
            </div>

            <div class="em-field" t-attf-class="{{ state.errors.institutionName ? 'em-field-error' : '' }}">
              <label class="em-label em-label-required">Institution Name</label>
              <input class="em-input"
                     type="text"
                     placeholder="e.g. Sunrise International School"
                     t-model="state.institutionName"/>
              <t t-if="state.errors.institutionName">
                <span class="em-error-msg"><t t-out="state.errors.institutionName"/></span>
              </t>
            </div>

          </div>

          <!-- Action Bar -->
          <div class="em-action-bar">
            <div/>
            <div class="em-action-right">
              <button class="em-btn-primary" t-on-click="nextStep">
                Continue
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </button>
            </div>
          </div>

        </div>

      </t><!-- /step 1 -->

      <!-- ── STEP 2 · Contact &amp; Location ─────────────────── -->
      <t t-if="state.step === 2">

        <div class="em-hero">
          <div class="em-hero-eyebrow">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:12px;height:12px">
              <path d="M2 12s2-4 6-4 6 4 6 4"/>
              <circle cx="8" cy="6" r="2"/>
            </svg>
            Contact &amp; Location
          </div>
          <h1 class="em-hero-title">How can we <em>reach you?</em></h1>
          <p class="em-hero-subtitle">
            Your contact details help parents and students find and connect with your institution.
          </p>
        </div>

        <div class="em-card" style="max-width:900px;width:100%">

          <!-- Contact Details -->
          <div class="em-card-section">
            <div class="em-section-label">
              <div class="em-section-label-dot"/>
              <span class="em-section-label-text">Contact Details</span>
            </div>

            <div class="em-grid-2">
              <div class="em-field" t-attf-class="{{ state.errors.email ? 'em-field-error' : '' }}">
                <label class="em-label em-label-required">Official Email</label>
                <input class="em-input" type="email" placeholder="principal@yourinstitution.edu"
                       t-model="state.email"/>
                <t t-if="state.errors.email">
                  <span class="em-error-msg"><t t-out="state.errors.email"/></span>
                </t>
                <t t-else="">
                  <span class="em-hint">Used for official communications and notifications</span>
                </t>
              </div>

              <div class="em-field" t-attf-class="{{ state.errors.phone ? 'em-field-error' : '' }}">
                <label class="em-label em-label-required">Phone Number</label>
                <input class="em-input" type="tel" placeholder="+91 98765 43210"
                       t-model="state.phone"/>
                <t t-if="state.errors.phone">
                  <span class="em-error-msg"><t t-out="state.errors.phone"/></span>
                </t>
              </div>

              <div class="em-field em-col-span-2">
                <label class="em-label">Website</label>
                <input class="em-input" type="url" placeholder="https://www.yourinstitution.edu"
                       t-model="state.website"/>
                <span class="em-hint">Optional — shown on parent-facing portals</span>
              </div>
            </div>
          </div>

          <div class="em-divider"/>

          <!-- Address -->
          <div class="em-card-section">
            <div class="em-section-label">
              <div class="em-section-label-dot"/>
              <span class="em-section-label-text">Address</span>
            </div>

            <div class="em-grid-2">
              <div class="em-field em-col-span-2">
                <label class="em-label">Street Address</label>
                <input class="em-input" type="text" placeholder="Building, Street, Area"
                       t-model="state.address"/>
              </div>

              <div class="em-field" t-attf-class="{{ state.errors.city ? 'em-field-error' : '' }}">
                <label class="em-label em-label-required">City</label>
                <input class="em-input" type="text" placeholder="e.g. Ahmedabad"
                       t-model="state.city"/>
                <t t-if="state.errors.city">
                  <span class="em-error-msg"><t t-out="state.errors.city"/></span>
                </t>
              </div>

              <div class="em-field">
                <label class="em-label">PIN / ZIP Code</label>
                <input class="em-input" type="text" placeholder="380001"
                       t-model="state.zip"/>
              </div>
            </div>
          </div>

          <div class="em-action-bar">
            <button class="em-btn-back" t-on-click="prevStep">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
              </svg>
              Back
            </button>
            <div class="em-action-right">
              <button class="em-btn-primary" t-on-click="nextStep">
                Continue
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </button>
            </div>
          </div>

        </div>

      </t><!-- /step 2 -->

      <!-- ── STEP 3 · Academics ─────────────────────────────── -->
      <t t-if="state.step === 3">

        <div class="em-hero">
          <div class="em-hero-eyebrow">
            <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="width:12px;height:12px">
              <path d="M2 13L8 3l6 10H2z"/>
            </svg>
            Academic Profile
          </div>
          <h1 class="em-hero-title">Your <em>academic</em> profile</h1>
          <p class="em-hero-subtitle">
            Help EduManage configure the right academic framework for your institution.
            All fields here are optional.
          </p>
        </div>

        <div class="em-card" style="max-width:900px;width:100%">

          <!-- Board -->
          <div class="em-card-section">
            <div class="em-section-label">
              <div class="em-section-label-dot"/>
              <span class="em-section-label-text">Board / Affiliation</span>
            </div>

            <div class="em-board-grid">
              <t t-foreach="getBoardOptions()" t-as="b" t-key="b.value">
                <div t-attf-class="em-board-card {{ state.board === b.value ? 'selected' : '' }}"
                     t-on-click="() =&gt; selectBoard(b.value)">
                  <div class="em-board-card-name"><t t-out="b.label"/></div>
                  <div class="em-board-card-sub"><t t-out="b.sub"/></div>
                </div>
              </t>
            </div>

            <div class="em-field" style="margin-top:20px">
              <label class="em-label">Affiliation / Registration Number</label>
              <input class="em-input" type="text" placeholder="e.g. 1234567 (optional)"
                     t-model="state.affNumber"/>
            </div>
          </div>

          <div class="em-divider"/>

          <!-- Year & Size -->
          <div class="em-card-section">
            <div class="em-section-label">
              <div class="em-section-label-dot"/>
              <span class="em-section-label-text">History &amp; Scale</span>
            </div>

            <div class="em-grid-2" style="margin-bottom:24px">
              <div class="em-field">
                <label class="em-label">Year Established</label>
                <input class="em-input" type="number" placeholder="e.g. 1998"
                       min="1800" max="2025" t-model="state.estYear"/>
              </div>
            </div>

            <div class="em-field">
              <label class="em-label">Approximate Student Strength</label>
              <span class="em-hint" style="margin-bottom:12px;display:block">
                Help us scale the right defaults for your institution
              </span>
              <div class="em-strength-grid">
                <t t-foreach="getStrengthOptions()" t-as="s" t-key="s.value">
                  <div t-attf-class="em-strength-pill {{ state.strength === s.value ? 'selected' : '' }}"
                       t-on-click="() =&gt; selectStrength(s.value)">
                    <t t-out="s.label"/>
                  </div>
                </t>
              </div>
            </div>
          </div>

          <div class="em-action-bar">
            <button class="em-btn-back" t-on-click="prevStep">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <line x1="19" y1="12" x2="5" y2="12"/>
                <polyline points="12 19 5 12 12 5"/>
              </svg>
              Back
            </button>
            <div class="em-action-right">
              <button t-attf-class="em-btn-primary em-btn-finish {{ state.saving ? 'disabled' : '' }}"
                      t-on-click="finishSetup"
                      t-att-disabled="state.saving">
                <t t-if="state.saving">
                  <svg class="em-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                    <line x1="12" y1="2" x2="12" y2="6"/>
                    <line x1="12" y1="18" x2="12" y2="22"/>
                    <line x1="4.93" y1="4.93" x2="7.76" y2="7.76"/>
                    <line x1="16.24" y1="16.24" x2="19.07" y2="19.07"/>
                    <line x1="2" y1="12" x2="6" y2="12"/>
                    <line x1="18" y1="12" x2="22" y2="12"/>
                    <line x1="4.93" y1="19.07" x2="7.76" y2="16.24"/>
                    <line x1="16.24" y1="7.76" x2="19.07" y2="4.93"/>
                  </svg>
                  Saving…
                </t>
                <t t-else="">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                  Complete Setup
                </t>
              </button>
            </div>
          </div>

        </div>

      </t><!-- /step 3 -->

    </main>

    <!-- ── Footer ────────────────────────────────────────────── -->
    <footer class="em-footer">
      <div class="em-trust-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
        </svg>
        Encrypted &amp; Secure
      </div>
      <div class="em-trust-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
        Works Offline
      </div>
      <div class="em-trust-badge">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
        Takes &lt; 5 Minutes
      </div>
    </footer>

    <!-- Hidden file input -->
    <input t-ref="fileInput" type="file" accept="image/*" class="em-file-hidden"
           t-on-change="onFileChange"/>

  </div><!-- /em-setup-shell -->

</t>

</templates>
