<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════
         Institution Form View — Premium post-setup editing
         ═══════════════════════════════════════════════════════ -->
    <record id="view_edumanage_institution_form" model="ir.ui.view">
        <field name="name">edumanage.institution.form</field>
        <field name="model">edumanage.institution</field>
        <field name="arch" type="xml">
            <form string="Institution" class="em-institution-form">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_complete_setup"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-check-circle"
                                invisible="setup_complete">
                            <span>Mark Setup Complete</span>
                        </button>
                    </div>

                    <!-- Logo & Name header -->
                    <widget name="web_ribbon"
                            title="Setup Complete"
                            bg_color="bg-success"
                            invisible="not setup_complete"/>

                    <field name="logo" widget="image"
                           class="oe_avatar"
                           options="{'preview_image': 'logo'}"/>

                    <div class="oe_title">
                        <label class="o_field_widget" for="name" string="Institution Name"/>
                        <h1>
                            <field name="name" placeholder="Institution Name"/>
                        </h1>
                        <field name="institution_type"
                               widget="radio"
                               options="{'horizontal': true}"/>
                    </div>

                    <notebook>
                        <page string="Contact Details" name="contact">
                            <group>
                                <group>
                                    <field name="email"/>
                                    <field name="phone"/>
                                    <field name="website" widget="url"/>
                                </group>
                                <group>
                                    <field name="established_year"/>
                                    <field name="total_students"/>
                                </group>
                            </group>
                            <separator string="Address"/>
                            <group>
                                <group>
                                    <field name="street"/>
                                    <field name="city"/>
                                    <field name="state_id"/>
                                </group>
                                <group>
                                    <field name="zip"/>
                                    <field name="country_id"/>
                                </group>
                            </group>
                        </page>

                        <page string="Academic Profile" name="academic">
                            <group>
                                <group>
                                    <field name="board_affiliation"/>
                                    <field name="affiliation_number"/>
                                </group>
                            </group>
                        </page>

                        <page string="Log" name="log">
                            <div class="oe_chatter">
                                <field name="message_follower_ids"/>
                                <field name="activity_ids"/>
                                <field name="message_ids"/>
                            </div>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Institution List View
         ═══════════════════════════════════════════════════════ -->
    <record id="view_edumanage_institution_list" model="ir.ui.view">
        <field name="name">edumanage.institution.list</field>
        <field name="model">edumanage.institution</field>
        <field name="arch" type="xml">
            <list string="Institutions">
                <field name="logo" widget="image" options="{'size': [32, 32]}"/>
                <field name="name"/>
                <field name="institution_type"/>
                <field name="city"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="setup_complete" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Institution Action
         ═══════════════════════════════════════════════════════ -->
    <record id="action_edumanage_institution" model="ir.actions.act_window">
        <field name="name">Institutions</field>
        <field name="res_model">edumanage.institution</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No institution configured yet
            </p>
            <p>
                Set up your first institution to get started with EduManage.
            </p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════
         Client Action — Full-Screen Onboarding
         ═══════════════════════════════════════════════════════ -->
    <record id="action_edumanage_setup_client" model="ir.actions.client">
        <field name="name">Institution Setup</field>
        <field name="tag">edumanage_setup.setup_action</field>
    </record>

</odoo>
