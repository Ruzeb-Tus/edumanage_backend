<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="edumanage_dashboard.Main" owl="1">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;family=Bricolage+Grotesque:wght@400;500;600;700;800&amp;display=swap"/>

  <div class="emd-shell">

    <!-- ══ SIDEBAR ══════════════════════════════════════════ -->
    <aside t-attf-class="emd-sidebar {{ state.sidebarCollapsed ? 'collapsed' : '' }}">

      <div class="emd-sidebar-logo" t-on-click="toggleSidebar">
        <div class="emd-sidebar-logo-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3L2 8l10 5 10-5-10-5zM2 14l10 5 10-5M2 19l10 5 10-5"/>
          </svg>
        </div>
        <span class="emd-wordmark">Edu<span>Manage</span></span>
      </div>

      <nav class="emd-nav">
        <t t-foreach="navItems" t-as="item" t-key="item.id">
          <div t-attf-class="emd-nav-item {{ state.activeNav === item.id ? 'active' : '' }}"
               t-on-click="() => setNav(item.id)">
            <svg viewBox="0 0 24 24" t-att-data-icon="item.id">
              <t t-out="item.iconPath"/>
            </svg>
            <span class="emd-nav-label"><t t-out="item.label"/></span>
          </div>
        </t>
      </nav>

      <div class="emd-sidebar-footer">
        <div class="emd-collapse-btn" t-on-click="toggleSidebar">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <polyline points="15 18 9 12 15 6"/>
          </svg>
          <span>Collapse</span>
        </div>
        <div class="emd-user-card">
          <div class="emd-user-avatar"><t t-out="state.userInitials"/></div>
          <div class="emd-user-info">
            <div class="emd-user-name"><t t-out="state.userName"/></div>
            <div class="emd-user-role">Administrator</div>
          </div>
        </div>
      </div>
    </aside>

    <!-- ══ MAIN ═════════════════════════════════════════════ -->
    <div class="emd-main">

      <header class="emd-header">
        <span class="emd-header-title"><t t-out="activeTitle"/></span>
        <div class="emd-search">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" placeholder="Search students, fees, classes…"/>
        </div>
        <div class="emd-header-actions">
          <div class="emd-icon-btn">
            <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
            <span class="emd-notif-dot"/>
          </div>
          <div class="emd-header-avatar"><t t-out="state.userInitials"/></div>
        </div>
      </header>

      <div class="emd-content">
        <div class="emd-inner">

          <!-- ══ DASHBOARD TAB ════════════════════════════════ -->
          <t t-if="state.activeNav === 'dashboard'">
            <!-- Greeting Hero -->
            <div class="emd-greeting">
              <div class="emd-greeting-left">
                <h1 class="emd-greeting-name"><t t-out="state.greetText"/>, <t t-out="state.userName"/></h1>
                <p class="emd-greeting-inst"><t t-out="state.institutionName"/></p>
                <p class="emd-greeting-date"><t t-out="state.dateCaps"/></p>
                <p class="emd-greeting-quote"><t t-out="state.dailyQuote"/></p>
              </div>
              <div class="emd-greeting-right">
                <div class="emd-greeting-deco"/>
              </div>
            </div>

            <!-- Alert Strip -->
            <t t-if="state.showAlert">
              <div class="emd-alert-strip">
                <div class="emd-alert-strip-items">
                  <div class="emd-alert-item">3 student birthdays today — Arjun, Priya, Meenal</div>
                  <div class="emd-alert-item">Fee deadline in 2 days — 47 students pending</div>
                  <div class="emd-alert-item">2 admission forms awaiting review</div>
                </div>
                <button class="emd-alert-dismiss" t-on-click="dismissAlert">✕</button>
              </div>
            </t>

            <!-- Metric Cards -->
            <div class="emd-metrics">
              <t t-foreach="metrics" t-as="m" t-key="m.id">
                <div t-attf-class="emd-metric-card accent-{{ m.accent }} {{ m.critical ? 'critical' : '' }}">
                  <div class="emd-metric-top">
                    <div class="emd-metric-icon-wrap">
                      <svg viewBox="0 0 24 24"><t t-out="m.iconPath"/></svg>
                    </div>
                  </div>
                  <div class="emd-metric-value-row">
                    <t t-if="m.prefix">
                      <span class="emd-metric-prefix"><t t-out="m.prefix"/></span>
                    </t>
                    <span class="emd-metric-value"><t t-out="m.value"/></span>
                  </div>
                  <div class="emd-metric-label"><t t-out="m.label"/></div>
                  <t t-if="m.trend">
                    <div class="emd-metric-divider"/>
                    <div t-attf-class="emd-metric-note {{ m.trendWarn ? 'warn' : '' }}">
                      <t t-out="m.trend"/>
                    </div>
                  </t>
                </div>
              </t>
            </div>

            <!-- Quick Actions -->
            <p class="emd-section-title">Quick Actions</p>
            <div class="emd-quick-actions">
              <button class="emd-action-btn" t-on-click="() => setNav('students')">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add Student
              </button>
              <button class="emd-action-btn" t-on-click="() => setNav('attendance')">
                <svg viewBox="0 0 24 24"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                Mark Attendance
              </button>
              <button class="emd-action-btn" t-on-click="() => setNav('fees')">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                Collect Fees
              </button>
              <button class="emd-action-btn" t-on-click="() => setNav('reports')">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                View Reports
              </button>
              <button class="emd-action-btn" t-on-click="() => setNav('documents')">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Upload Documents
              </button>
            </div>

            <!-- Shortcuts -->
            <p class="emd-section-title">Shortcuts</p>
            <div class="emd-shortcuts">
              <t t-foreach="shortcuts" t-as="sc" t-key="sc.id">
                <div class="emd-shortcut" t-on-click="() => setNav(sc.id)">
                  <div class="emd-shortcut-icon">
                    <svg viewBox="0 0 24 24"><t t-out="sc.iconPath"/></svg>
                  </div>
                  <div class="emd-shortcut-name"><t t-out="sc.label"/></div>
                  <div class="emd-shortcut-desc"><t t-out="sc.desc"/></div>
                </div>
              </t>
            </div>

            <!-- Focus + Activity -->
            <div class="emd-three-col">
              <div class="emd-panel">
                <div class="emd-panel-header">
                  <span class="emd-panel-title">Today's Focus</span>
                </div>
                <div class="emd-panel-body">
                  <div class="emd-focus-item" t-on-click="() => setNav('fees')">
                    <div class="emd-focus-dot warn"/>
                    <div class="emd-focus-text">
                      <div class="emd-focus-label">Fees Due Today</div>
                      <div class="emd-focus-sub">₹48,500 across 12 students</div>
                    </div>
                    <span class="emd-focus-badge warn">12</span>
                    <span class="emd-view-link">View →</span>
                  </div>
                  <div class="emd-focus-item" t-on-click="() => setNav('fees')">
                    <div class="emd-focus-dot warn"/>
                    <div class="emd-focus-text">
                      <div class="emd-focus-label">Overdue Fees</div>
                      <div class="emd-focus-sub">Students with dues &gt; 30 days</div>
                    </div>
                    <span class="emd-focus-badge warn">8</span>
                    <span class="emd-view-link">View →</span>
                  </div>
                  <div class="emd-focus-item" t-on-click="() => setNav('attendance')">
                    <div class="emd-focus-dot"/>
                    <div class="emd-focus-text">
                      <div class="emd-focus-label">Attendance Unmarked</div>
                      <div class="emd-focus-sub">3 classes not yet marked</div>
                    </div>
                    <span class="emd-focus-badge">3</span>
                    <span class="emd-view-link">Mark →</span>
                  </div>
                </div>
              </div>

              <div class="emd-panel">
                <div class="emd-panel-header">
                  <span class="emd-panel-title">
                    <span class="emd-live-dot"/>
                    Live Activity
                  </span>
                </div>
                <div class="emd-panel-body">
                  <ul class="emd-feed">
                    <t t-foreach="activityFeed" t-as="act" t-key="act.id">
                      <li class="emd-feed-item">
                        <div t-attf-class="emd-feed-dot {{ act.color }}"/>
                        <div class="emd-feed-body">
                          <div class="emd-feed-title"><t t-out="act.title"/></div>
                          <div class="emd-feed-meta"><t t-out="act.meta"/></div>
                        </div>
                      </li>
                    </t>
                  </ul>
                </div>
              </div>
            </div>
          </t>

          <!-- ══ STUDENTS TAB ═════════════════════════════════ -->
          <t t-elif="state.activeNav === 'students'">

            <!-- ── New Admission Form ───────────────────────── -->
            <t t-if="state.studentsView === 'admission'">
              <div class="emd-admission-wrap">
                <div class="emd-admission-header">
                  <button class="emd-btn-back" t-on-click="backToRoster">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to Students
                  </button>
                  <div class="emd-admission-header-text">
                    <h2 class="emd-page-bar-title">New Student Admission</h2>
                    <p class="emd-admission-subtitle">Register a new student with class and section assignment</p>
                  </div>
                </div>

                <t t-if="state.admissionErrors._form">
                  <div class="emd-admission-form-error"><t t-out="state.admissionErrors._form"/></div>
                </t>

                <form class="emd-admission-form" t-on-submit.prevent="saveAdmission">
                  <!-- Student Information -->
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Student Information</div>
                    <div class="em-grid-2">
                      <div t-attf-class="em-field {{ state.admissionErrors.name ? 'em-field-error' : '' }}">
                        <label class="em-label em-label-required">Student Name</label>
                        <input type="text" class="em-input" placeholder="Enter full name"
                               t-model="state.admissionForm.name"/>
                        <t t-if="state.admissionErrors.name">
                          <span class="em-error-msg"><t t-out="state.admissionErrors.name"/></span>
                        </t>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Student Photo</label>
                        <div class="emd-photo-upload">
                          <t t-if="state.admissionForm.photoPreview">
                            <div class="emd-photo-preview">
                              <img t-att-src="state.admissionForm.photoPreview" alt="Student photo"/>
                              <button type="button" class="emd-photo-remove" t-on-click="removePhoto">✕</button>
                            </div>
                          </t>
                          <t t-else="">
                            <label class="emd-photo-dropzone">
                              <input type="file" accept="image/*" t-on-change="onPhotoSelect"/>
                              <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                              <span>Upload photo</span>
                            </label>
                          </t>
                        </div>
                      </div>
                      <div class="em-field">
                        <label class="em-label em-label-required">Gender</label>
                        <select class="em-select" t-model="state.admissionForm.gender">
                          <option value="male">Male</option>
                          <option value="female">Female</option>
                          <option value="other">Other</option>
                        </select>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Date of Birth</label>
                        <input type="date" class="em-input" t-model="state.admissionForm.date_of_birth"/>
                      </div>
                    </div>
                  </div>

                  <!-- Academic Information -->
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Academic Information</div>
                    <div class="em-grid-2">
                      <div t-attf-class="em-field {{ state.admissionErrors.class_id ? 'em-field-error' : '' }}">
                        <label class="em-label em-label-required">Class</label>
                        <select class="em-select" t-model="state.admissionForm.class_id"
                                t-on-change="onAdmissionClassChange">
                          <option value="">Select class</option>
                          <t t-foreach="state.classesOptions" t-as="cls" t-key="cls.id">
                            <option t-att-value="cls.id"><t t-out="cls.name"/></option>
                          </t>
                        </select>
                        <t t-if="state.admissionErrors.class_id">
                          <span class="em-error-msg"><t t-out="state.admissionErrors.class_id"/></span>
                        </t>
                      </div>
                      <div t-attf-class="em-field {{ state.admissionErrors.section_id ? 'em-field-error' : '' }}">
                        <label class="em-label em-label-required">Section</label>
                        <select class="em-select" t-model="state.admissionForm.section_id"
                                t-att-disabled="!state.admissionForm.class_id">
                          <option value="">Select section</option>
                          <t t-foreach="admissionSections" t-as="sec" t-key="sec.id">
                            <option t-att-value="sec.id"><t t-out="sec.name"/></option>
                          </t>
                        </select>
                        <t t-if="state.admissionErrors.section_id">
                          <span class="em-error-msg"><t t-out="state.admissionErrors.section_id"/></span>
                        </t>
                      </div>
                      <div t-attf-class="em-field {{ state.admissionErrors.admission_date ? 'em-field-error' : '' }}">
                        <label class="em-label em-label-required">Admission Date</label>
                        <input type="date" class="em-input" t-model="state.admissionForm.admission_date"/>
                        <t t-if="state.admissionErrors.admission_date">
                          <span class="em-error-msg"><t t-out="state.admissionErrors.admission_date"/></span>
                        </t>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Roll Number</label>
                        <input type="text" class="em-input" placeholder="e.g. 12"
                               t-model="state.admissionForm.roll_no"/>
                      </div>
                    </div>
                  </div>

                  <!-- Parent Information -->
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Parent Information</div>
                    <div class="em-grid-2">
                      <div class="em-field">
                        <label class="em-label">Father Name</label>
                        <input type="text" class="em-input" placeholder="Father's full name"
                               t-model="state.admissionForm.father_name"/>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Mother Name</label>
                        <input type="text" class="em-input" placeholder="Mother's full name"
                               t-model="state.admissionForm.mother_name"/>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Mobile Number</label>
                        <input type="tel" class="em-input" placeholder="+91 98765 43210"
                               t-model="state.admissionForm.parent_phone"/>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Email</label>
                        <input type="email" class="em-input" placeholder="parent@email.com"
                               t-model="state.admissionForm.parent_email"/>
                      </div>
                    </div>
                  </div>

                  <!-- Address Information -->
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Address Information</div>
                    <div class="em-grid-2">
                      <div class="em-field em-col-span-2" style="grid-column: span 2">
                        <label class="em-label">Address</label>
                        <textarea class="em-input emd-textarea" rows="3" placeholder="Street address"
                                  t-model="state.admissionForm.address"/>
                      </div>
                      <div class="em-field">
                        <label class="em-label">City</label>
                        <input type="text" class="em-input" placeholder="City"
                               t-model="state.admissionForm.city"/>
                      </div>
                      <div class="em-field">
                        <label class="em-label">Country</label>
                        <select class="em-select" t-model="state.admissionForm.country_id"
                                t-on-change="onAdmissionCountryChange">
                          <option value="">Select country</option>
                          <t t-foreach="state.countries" t-as="country" t-key="country.id">
                            <option t-att-value="country.id"><t t-out="country.name"/></option>
                          </t>
                        </select>
                      </div>
                      <div class="em-field">
                        <label class="em-label">State</label>
                        <select class="em-select" t-model="state.admissionForm.state_id"
                                t-att-disabled="!state.admissionForm.country_id">
                          <option value="">Select state</option>
                          <t t-foreach="state.states" t-as="st" t-key="st.id">
                            <option t-att-value="st.id"><t t-out="st.name"/></option>
                          </t>
                        </select>
                      </div>
                    </div>
                  </div>

                  <div class="emd-admission-actions">
                    <button type="button" class="em-btn-back emd-btn-cancel" t-on-click="cancelAdmission">Cancel</button>
                    <button type="submit" class="em-btn-primary" t-att-disabled="state.admissionSaving">
                      <t t-if="state.admissionSaving">Saving…</t>
                      <t t-else="">Save Admission</t>
                    </button>
                  </div>
                </form>
              </div>
            </t>

            <!-- ── Student Profile ──────────────────────────── -->
            <t t-elif="state.studentsView === 'profile' and state.selectedStudent">
              <div class="emd-profile-wrap">
                <div class="emd-admission-header">
                  <button class="emd-btn-back" t-on-click="backToRoster">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                    Back to Students
                  </button>
                </div>

                <div class="emd-profile-hero">
                  <div class="emd-profile-hero-left">
                    <t t-if="photoSrc(state.selectedStudent)">
                      <img class="emd-profile-photo" t-att-src="photoSrc(state.selectedStudent)" alt="Student"/>
                    </t>
                    <t t-else="">
                      <div t-attf-class="emd-student-avatar emd-profile-avatar {{ state.selectedStudent.gender === 'female' ? 'female' : '' }}">
                        <t t-out="state.selectedStudent.initials"/>
                      </div>
                    </t>
                    <div>
                      <h2 class="emd-profile-name"><t t-out="state.selectedStudent.name"/></h2>
                      <p class="emd-profile-meta">
                        ID: <t t-out="state.selectedStudent.studentId"/> ·
                        <t t-out="state.selectedStudent.className"/>
                      </p>
                      <span t-attf-class="emd-student-status {{ state.selectedStudent.status }}">
                        <t t-out="state.selectedStudent.statusLabel"/>
                      </span>
                    </div>
                  </div>
                  <div class="emd-profile-stats">
                    <div class="emd-profile-stat">
                      <span class="emd-profile-stat-value"><t t-out="state.selectedStudent.attendancePct"/>%</span>
                      <span class="emd-profile-stat-label">Attendance</span>
                    </div>
                    <div class="emd-profile-stat">
                      <span class="emd-profile-stat-value"><t t-out="state.selectedStudent.feeStatus"/></span>
                      <span class="emd-profile-stat-label">Fee Status</span>
                    </div>
                  </div>
                </div>

                <div class="emd-profile-grid">
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Student Information</div>
                    <div class="emd-profile-fields">
                      <div class="emd-profile-field"><span>Gender</span><strong t-out="formatGender(state.selectedStudent.gender)"/></div>
                      <div class="emd-profile-field"><span>Date of Birth</span><strong t-out="state.selectedStudent.dob or '—'"/></div>
                    </div>
                  </div>
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Academic Information</div>
                    <div class="emd-profile-fields">
                      <div class="emd-profile-field"><span>Class</span><strong t-out="formatMany2one(state.selectedStudent.class_id)"/></div>
                      <div class="emd-profile-field"><span>Section</span><strong t-out="formatMany2one(state.selectedStudent.section_id)"/></div>
                      <div class="emd-profile-field"><span>Admission Date</span><strong t-out="state.selectedStudent.admission_date or '—'"/></div>
                      <div class="emd-profile-field"><span>Roll Number</span><strong t-out="state.selectedStudent.rollNo or '—'"/></div>
                    </div>
                  </div>
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Parent Information</div>
                    <div class="emd-profile-fields">
                      <div class="emd-profile-field"><span>Father Name</span><strong t-out="state.selectedStudent.father_name or '—'"/></div>
                      <div class="emd-profile-field"><span>Mother Name</span><strong t-out="state.selectedStudent.mother_name or '—'"/></div>
                      <div class="emd-profile-field"><span>Mobile</span><strong t-out="state.selectedStudent.parent_phone or '—'"/></div>
                      <div class="emd-profile-field"><span>Email</span><strong t-out="state.selectedStudent.parent_email or '—'"/></div>
                    </div>
                  </div>
                  <div class="em-card emd-admission-card">
                    <div class="em-section-label">Address Information</div>
                    <div class="emd-profile-fields">
                      <div class="emd-profile-field emd-profile-field-full"><span>Address</span><strong t-out="state.selectedStudent.address or '—'"/></div>
                      <div class="emd-profile-field"><span>City</span><strong t-out="state.selectedStudent.city or '—'"/></div>
                      <div class="emd-profile-field"><span>State</span><strong t-out="formatMany2one(state.selectedStudent.state_id)"/></div>
                      <div class="emd-profile-field"><span>Country</span><strong t-out="formatMany2one(state.selectedStudent.country_id)"/></div>
                    </div>
                  </div>
                </div>
              </div>
            </t>

            <!-- ── Student Roster (unchanged) ───────────────── -->
            <t t-else="">
            <div class="emd-page-bar">
              <div class="emd-page-bar-left">
                <h2 class="emd-page-bar-title">
                  <t t-if="state.studentsSubTab === 'classes'">Manage Classes</t>
                  <t t-else="">Student Roster</t>
                </h2>
                <span class="emd-page-bar-count">
                  <t t-if="state.studentsSubTab === 'classes'">
                    <t t-out="classesData.length"/> Classes
                  </t>
                  <t t-else="">
                    <t t-out="filteredStudents.length"/> Students
                  </t>
                </span>
              </div>
              <div class="emd-page-bar-right">
                <div class="emd-sub-tabs">
                  <button t-attf-class="emd-sub-tab {{ state.studentsSubTab === 'roster' ? 'active' : '' }}"
                          t-on-click="() => setStudentsSubTab('roster')">
                    <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;vertical-align:-2px;margin-right:4px">
                      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                    </svg>
                    Students
                  </button>
                  <button t-attf-class="emd-sub-tab {{ state.studentsSubTab === 'classes' ? 'active' : '' }}"
                          t-on-click="() => setStudentsSubTab('classes')">
                    <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;vertical-align:-2px;margin-right:4px">
                      <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    Classes
                  </button>
                </div>
                <button class="emd-btn-add" t-on-click="openNewAdmission">
                  <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                  <t t-if="state.studentsSubTab === 'classes'">Add Class</t>
                  <t t-else="">New Admission</t>
                </button>
              </div>
            </div>

            <!-- ── Students Roster Sub-Tab ──────────────────── -->
            <t t-if="state.studentsSubTab === 'roster'">

              <!-- Filter Bar -->
              <div class="emd-filter-bar">
                <t t-foreach="getStudentFilters()" t-as="f" t-key="f.id">
                  <div t-attf-class="emd-filter-pill {{ state.studentFilter === f.id ? 'active' : '' }}"
                       t-on-click="() => setStudentFilter(f.id)">
                    <t t-out="f.label"/>
                    <t t-if="f.count">
                      <span style="opacity:0.7">·</span> <t t-out="f.count"/>
                    </t>
                  </div>
                </t>
                <div class="emd-filter-search" style="margin-left:auto">
                  <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                  <input type="text" placeholder="Search students…"
                         t-model="state.studentSearch"
                         t-on-input="onStudentSearch"/>
                </div>
              </div>

              <!-- Kanban Grid -->
              <div class="emd-kanban-grid">
                <t t-foreach="filteredStudents" t-as="s" t-key="s.id">
                  <div class="emd-student-card">
                    <div class="emd-student-card-top">
                      <div t-attf-class="emd-student-avatar {{ s.gender === 'female' ? 'female' : '' }}">
                        <t t-out="s.initials"/>
                      </div>
                      <div class="emd-student-info">
                        <div class="emd-student-name"><t t-out="s.name"/></div>
                        <div class="emd-student-id">ID: <t t-out="s.studentId"/> · <t t-out="s.className"/></div>
                      </div>
                      <span t-attf-class="emd-student-status {{ s.status }}">
                        <t t-out="s.statusLabel"/>
                      </span>
                    </div>

                    <div class="emd-student-details">
                      <div class="emd-student-detail">
                        <span class="emd-student-detail-label">Class</span>
                        <span class="emd-student-detail-value"><t t-out="s.className"/></span>
                      </div>
                      <div class="emd-student-detail">
                        <span class="emd-student-detail-label">Roll No</span>
                        <span class="emd-student-detail-value"><t t-out="s.rollNo"/></span>
                      </div>
                      <div class="emd-student-detail">
                        <span class="emd-student-detail-label">Guardian</span>
                        <span class="emd-student-detail-value"><t t-out="s.guardian"/></span>
                      </div>
                      <div class="emd-student-detail">
                        <span class="emd-student-detail-label">Fee Status</span>
                        <span class="emd-student-detail-value"><t t-out="s.feeStatus"/></span>
                      </div>
                    </div>

                    <div class="emd-student-card-footer">
                      <div class="emd-student-attendance">
                        <div t-attf-class="emd-student-attendance-dot {{ s.attendancePct &lt; 85 ? 'warn' : '' }}"/>
                        <t t-out="s.attendancePct"/>% Attendance
                      </div>
                      <span class="emd-student-view" t-on-click="() => openStudentProfile(s.id)">View Profile →</span>
                    </div>
                  </div>
                </t>
              </div>

              <!-- Empty State -->
              <t t-if="filteredStudents.length === 0">
                <div class="emd-empty-state">
                  <div class="emd-empty-icon">
                    <svg viewBox="0 0 24 24">
                      <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                    </svg>
                  </div>
                  <div class="emd-empty-title">No students found</div>
                  <div class="emd-empty-desc">Try adjusting your search or filter criteria to find students.</div>
                </div>
              </t>
            </t>

            <!-- ── Manage Classes Sub-Tab ───────────────────── -->
            <t t-if="state.studentsSubTab === 'classes'">
              <div class="emd-classes-grid">
                <t t-foreach="classesData" t-as="c" t-key="c.id">
                  <div class="emd-class-card">
                    <div class="emd-class-header">
                      <div class="emd-class-icon">
                        <svg viewBox="0 0 24 24">
                          <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                        </svg>
                      </div>
                      <span class="emd-class-badge"><t t-out="c.section"/></span>
                    </div>
                    <div class="emd-class-name"><t t-out="c.name"/></div>
                    <div class="emd-class-teacher">
                      <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:var(--emd-text-3);fill:none;stroke-width:2;stroke-linecap:round;vertical-align:-1px;margin-right:4px">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                      </svg>
                      <t t-out="c.teacher"/>
                    </div>
                    <div class="emd-class-stats">
                      <div class="emd-class-stat">
                        <span class="emd-class-stat-value"><t t-out="c.students"/></span>
                        <span class="emd-class-stat-label">Students</span>
                      </div>
                      <div class="emd-class-stat">
                        <span class="emd-class-stat-value"><t t-out="c.attendance"/>%</span>
                        <span class="emd-class-stat-label">Attendance</span>
                      </div>
                      <div class="emd-class-stat">
                        <span class="emd-class-stat-value"><t t-out="c.subjects"/></span>
                        <span class="emd-class-stat-label">Subjects</span>
                      </div>
                    </div>
                  </div>
                </t>
              </div>
            </t>

            </t>

          </t>

          <!-- ══ ATTENDANCE TAB ═══════════════════════════════ -->
          <t t-elif="state.activeNav === 'attendance'">
            <div class="emd-panel">
              <div class="emd-panel-header">
                <span class="emd-panel-title">Daily Class Attendance Tracker</span>
              </div>
              <div class="emd-panel-body">
                <div style="display: grid; gap: 12px; margin-top: 12px;">
                  <!-- Class 1 -->
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px; border: 1px solid var(--emd-border); border-radius: 12px; background: rgba(255, 255, 255, 0.01);">
                    <div>
                      <div style="font-size: 14px; font-weight: 600;">Class 10A</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">32/32 Marked · Today 09:15 AM</div>
                    </div>
                    <button class="emd-action-btn" style="padding: 6px 12px; border-radius: 8px; border-color: rgba(0, 196, 140, 0.3); background: rgba(0, 196, 140, 0.1); color: var(--emd-emerald);">Completed</button>
                  </div>
                  <!-- Class 2 -->
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px; border: 1px solid var(--emd-border); border-radius: 12px; background: rgba(255, 255, 255, 0.01);">
                    <div>
                      <div style="font-size: 14px; font-weight: 600;">Class 9B</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Pending · Due by 12:00 PM</div>
                    </div>
                    <button class="emd-action-btn" style="padding: 6px 12px; border-radius: 8px;">Mark Attendance</button>
                  </div>
                </div>
              </div>
            </div>
          </t>

          <!-- ══ FEES TAB ═════════════════════════════════════ -->
          <t t-elif="state.activeNav === 'fees'">
            <div class="emd-panel">
              <div class="emd-panel-header">
                <span class="emd-panel-title">Pending &amp; Outstanding Collections</span>
              </div>
              <div class="emd-panel-body">
                <div style="display: grid; gap: 12px; margin-top: 12px;">
                  <!-- Fee 1 -->
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px; border: 1px solid var(--emd-border); border-radius: 12px; background: rgba(255, 255, 255, 0.01);">
                    <div>
                      <div style="font-size: 14px; font-weight: 600;">Priya Mehta</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Term 2 Fees · Class 9B</div>
                    </div>
                    <div style="text-align: right;">
                      <div style="font-size: 14px; font-weight: 600; color: var(--emd-amber);">₹8,500 Due</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Overdue 2 days</div>
                    </div>
                  </div>
                  <!-- Fee 2 -->
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px; border: 1px solid var(--emd-border); border-radius: 12px; background: rgba(255, 255, 255, 0.01);">
                    <div>
                      <div style="font-size: 14px; font-weight: 600;">Rahul Verma</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Activity Charges · Class 10A</div>
                    </div>
                    <div style="text-align: right;">
                      <div style="font-size: 14px; font-weight: 600; color: var(--emd-amber);">₹5,200 Due</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Overdue 5 days</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </t>

          <!-- ══ DOCUMENTS TAB ════════════════════════════════ -->
          <t t-elif="state.activeNav === 'documents'">
            <div class="emd-panel">
              <div class="emd-panel-header">
                <span class="emd-panel-title">Document Hub</span>
              </div>
              <div class="emd-panel-body">
                <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 12px;">
                  <!-- Folder 1 -->
                  <div style="padding: 20px; border: 1px solid var(--emd-border); border-radius: 16px; background: rgba(255, 255, 255, 0.01); cursor: pointer;">
                    <div style="font-size: 24px; margin-bottom: 10px;">📁</div>
                    <div style="font-size: 14px; font-weight: 600;">Student Records</div>
                    <div style="font-size: 12px; color: var(--emd-text-3);">128 files</div>
                  </div>
                  <!-- Folder 2 -->
                  <div style="padding: 20px; border: 1px solid var(--emd-border); border-radius: 16px; background: rgba(255, 255, 255, 0.01); cursor: pointer;">
                    <div style="font-size: 24px; margin-bottom: 10px;">📁</div>
                    <div style="font-size: 14px; font-weight: 600;">Fee Invoices</div>
                    <div style="font-size: 12px; color: var(--emd-text-3);">412 files</div>
                  </div>
                  <!-- Folder 3 -->
                  <div style="padding: 20px; border: 1px solid var(--emd-border); border-radius: 16px; background: rgba(255, 255, 255, 0.01); cursor: pointer;">
                    <div style="font-size: 24px; margin-bottom: 10px;">📁</div>
                    <div style="font-size: 14px; font-weight: 600;">Curriculum Plans</div>
                    <div style="font-size: 12px; color: var(--emd-text-3);">34 files</div>
                  </div>
                </div>
              </div>
            </div>
          </t>

          <!-- ══ REPORTS TAB ══════════════════════════════════ -->
          <t t-elif="state.activeNav === 'reports'">
            <div class="emd-panel">
              <div class="emd-panel-header">
                <span class="emd-panel-title">Academic &amp; Financial Reports</span>
              </div>
              <div class="emd-panel-body">
                <div style="display: grid; gap: 12px; margin-top: 12px;">
                  <!-- Report 1 -->
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px; border: 1px solid var(--emd-border); border-radius: 12px; background: rgba(255, 255, 255, 0.01);">
                    <div>
                      <div style="font-size: 14px; font-weight: 600;">Monthly Collection Report</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Financial reconciliation report for May 2026</div>
                    </div>
                    <button class="emd-action-btn" style="padding: 6px 12px; border-radius: 8px;">Download PDF</button>
                  </div>
                  <!-- Report 2 -->
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 14px; border: 1px solid var(--emd-border); border-radius: 12px; background: rgba(255, 255, 255, 0.01);">
                    <div>
                      <div style="font-size: 14px; font-weight: 600;">Attendance Summary</div>
                      <div style="font-size: 12px; color: var(--emd-text-3);">Aggregated attendance stats for Term 1</div>
                    </div>
                    <button class="emd-action-btn" style="padding: 6px 12px; border-radius: 8px;">Download Excel</button>
                  </div>
                </div>
              </div>
            </div>
          </t>

          <!-- ══ TIMETABLE TAB ════════════════════════════════ -->
          <t t-elif="state.activeNav === 'timetable'">
            <div class="emd-panel">
              <div class="emd-panel-header">
                <span class="emd-panel-title">Weekly Timetable Grid</span>
              </div>
              <div class="emd-panel-body">
                <div style="margin-top: 12px; border: 1px solid var(--emd-border); border-radius: 12px; overflow: hidden;">
                  <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 13px;">
                    <thead>
                      <tr style="background: rgba(255,255,255,0.02); border-bottom: 1px solid var(--emd-border);">
                        <th style="padding: 12px;">Time</th>
                        <th style="padding: 12px;">Monday</th>
                        <th style="padding: 12px;">Tuesday</th>
                        <th style="padding: 12px;">Wednesday</th>
                      </tr>
                    </thead>
                    <tbody>
                      <tr style="border-bottom: 1px solid var(--emd-border);">
                        <td style="padding: 12px; font-weight: 600;">09:00 - 10:00</td>
                        <td style="padding: 12px;">Mathematics · Class 10A</td>
                        <td style="padding: 12px;">Physics · Class 9B</td>
                        <td style="padding: 12px;">English · Class 10A</td>
                      </tr>
                      <tr>
                        <td style="padding: 12px; font-weight: 600;">10:00 - 11:00</td>
                        <td style="padding: 12px;">Science · Class 9B</td>
                        <td style="padding: 12px;">Chemistry · Class 10A</td>
                        <td style="padding: 12px;">History · Class 9B</td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </t>

          <!-- ══ SETTINGS TAB ═════════════════════════════════ -->
          <t t-elif="state.activeNav === 'settings'">
            <div class="emd-panel">
              <div class="emd-panel-header">
                <span class="emd-panel-title">System &amp; General Settings</span>
              </div>
              <div class="emd-panel-body">
                <div style="display: grid; gap: 16px; margin-top: 12px; max-width: 500px;">
                  <div>
                    <label style="display: block; font-size: 12px; color: var(--emd-text-label); text-transform: uppercase; margin-bottom: 6px;">Institution Name</label>
                    <input type="text" t-att-value="state.institutionName" style="width: 100%; padding: 10px; border-radius: 8px; border: 1px solid var(--emd-border); background: rgba(255,255,255,0.02); color: white; outline: none;"/>
                  </div>
                  <div>
                    <label style="display: block; font-size: 12px; color: var(--emd-text-label); text-transform: uppercase; margin-bottom: 6px;">Email Notifications</label>
                    <div style="display: flex; align-items: center; gap: 8px; font-size: 13px;">
                      <input type="checkbox" checked="checked" style="width: 16px; height: 16px;"/>
                      <span>Send daily attendance digests to admin</span>
                    </div>
                  </div>
                  <button class="emd-action-btn" style="margin-top: 12px; align-self: flex-start;">Save Changes</button>
                </div>
              </div>
            </div>
          </t>

        </div>
      </div>
    </div>
  </div>
</t>

</templates>
