<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sequence for Student ID -->
    <record id="sequence_edumanage_student" model="ir.sequence">
        <field name="name">Student Admission Sequence</field>
        <field name="code">edumanage.student</field>
        <field name="prefix">EDU-2026-</field>
        <field name="padding">4</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Fee Structure -->
    <record id="sequence_edumanage_fee_structure" model="ir.sequence">
        <field name="name">Fee Structure Sequence</field>
        <field name="code">edumanage.fee.structure</field>
        <field name="prefix">FEE-2026-</field>
        <field name="padding">3</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Sequence for Fee Payment / Receipt -->
    <record id="sequence_edumanage_fee_payment" model="ir.sequence">
        <field name="name">Fee Payment Sequence</field>
        <field name="code">edumanage.fee.payment</field>
        <field name="prefix">REC-</field>
        <field name="padding">4</field>
        <field name="number_next">1001</field>
        <field name="number_increment">1</field>
        <field name="company_id" eval="False"/>
    </record>
    <!-- Sample Classes -->
    <record id="class_10" model="edumanage.class">
        <field name="name">Class 10</field>
    </record>
