        <field name="name">Class 9</field>
    </record>
    <record id="class_8" model="edumanage.class">
        <field name="name">Class 8</field>
    </record>
    <record id="class_7" model="edumanage.class">
        <field name="name">Class 7</field>
    </record>
    <record id="class_6" model="edumanage.class">
        <field name="name">Class 6</field>
    </record>
    <record id="class_5" model="edumanage.class">
        <field name="name">Class 5</field>
    </record>

    <!-- Sample Sections -->
    <record id="section_10a" model="edumanage.section">
        <field name="name">A</field>
        <field name="class_id" ref="class_10"/>
    </record>
    <record id="section_10b" model="edumanage.section">
        <field name="name">B</field>
        <field name="class_id" ref="class_10"/>
    </record>
    <record id="section_10c" model="edumanage.section">
